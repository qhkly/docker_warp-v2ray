# 复制为 .env 后按需修改。所有变量都有默认值，可全部留空。

# ---- 配置来源 ----
# patch    : 挂载现有 config.json 到 ./config/，仅追加安全加固（默认，推荐迁移用）
# generate : 从下面的 VMESS_UUID / XRAY_PORT 生成一份全新配置
CONFIG_MODE=patch

# CONFIG_MODE=generate 时必填
VMESS_UUID=

# ---- WARP ----
# MASQUE : HTTP/3 over QUIC，链路上像普通 CDN 流量。国内可用的关键，默认值
# WireGuard : 无混淆，特征明显，国内大概率不通
WARP_PROTOCOL=MASQUE

# warp  : TUN 全隧道，支持 UDP（默认）
# proxy : 仅 SOCKS5 转发，完全不支持 UDP
WARP_MODE=warp

# WARP+ 授权码，留空则用免费额度
WARP_LICENSE=

# ---- Xray ----
# 健康检查探测的端口，需与 inbounds 监听端口一致
XRAY_PORT=9000

# ---- 高级（一般不用改）----
# 策略路由使用的 fwmark / 路由表号 / 规则优先级
# ROUTE_MARK=0x1
# ROUTE_TABLE=100
# ROUTE_RULE_PRIO=100
# WARP 看护循环的检查间隔（秒）
# WATCHDOG_INTERVAL=30
