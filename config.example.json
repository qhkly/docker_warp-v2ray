{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "listen": "0.0.0.0",
      "port": 9000,
      "protocol": "vmess",
      "settings": {
        "clients": [
          {
            "id": "REPLACE_WITH_YOUR_UUID",
            "level": 1,
            "alterId": 0
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "none"
      },
      "tag": "vmess-in"
    },
    {
      "listen": "0.0.0.0",
      "port": 9001,
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": true
      },
      "tag": "socks-in"
    },
    {
      "listen": "0.0.0.0",
      "port": 9002,
      "protocol": "http",
      "settings": {},
      "tag": "http-in"
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "settings": {},
      "tag": "direct"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "inboundTag": [
          "vmess-in",
          "socks-in",
          "http-in"
        ],
        "outboundTag": "direct"
      }
    ]
  }
}
